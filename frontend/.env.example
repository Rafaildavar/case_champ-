# URL бэкенда для fetch из мини-приложения (без слэша в конце пути до /api/v1).
# В проде: полный HTTPS-домен API. Страница VK открывается по HTTPS — смешанный контент
# (HTTPS фронт → HTTP API) в WebView на телефоне и в десктопе VK обычно блокируется.
# Значение подставляется на этапе сборки (npm run build), не в рантайме.
VITE_API_URL=https://your-api.example.com/api/v1
